# Supply-chain pinning (S-I-4 / D-I-1 / AC-I-9, D-M-6, S-I-5).
# Upgrade process: bump the ARG default, rebuild base, run smoke tests,
# commit.  CI can override with --build-arg to validate new candidates.
#
# BUN_IMAGE_TAG note: Archon main uses bun.lock (JSON, lockfileVersion 1)
# which requires Bun >= 1.2.  The old 1.1.42 pin broke on re-builds
# when Docker Hub republished its tag with a newer Bun binary anyway
# (supply-chain tag drift, proven by a stale local image reporting
# "Bun v1.3.12" from an image nominally built on 1.1.42).  Pin to a
# concrete 1.2.x tag and treat tag drift as a known risk — a digest
# pin (@sha256:...) is the long-term fix tracked for v2.
ARG BUN_IMAGE_TAG=oven/bun:1.2.17
# Pinned to the Archon main SHA verified during EPIC #96 development.
# Override at build time: --build-arg ARCHON_SHA=<40-char-hex>
ARG ARCHON_SHA=6be5c61620890dadc20500e8219a02b64f5c3060
ARG NODE_IMAGE=node:22-slim

FROM ${BUN_IMAGE_TAG} AS archon-deps

# Install Archon from source (not the compiled binary).
# The compiled Bun binary has a $bunfs extraction issue that prevents
# the Claude Agent SDK from spawning child processes as a non-root user.
# Running from source with bun matches Archon's own Docker setup.
ARG ARCHON_SHA
WORKDIR /opt/archon
RUN apt-get update && apt-get install -y --no-install-recommends git ca-certificates && \
    rm -rf /var/lib/apt/lists/*
# Validate that ARCHON_SHA looks like a 40-char hex commit hash.
# Branch names (e.g. "main") are rejected — they make the build
# non-reproducible and the PR claim "verified against v0.3.6" dishonest.
RUN echo "${ARCHON_SHA}" | grep -qE '^[0-9a-f]{40}$' || \
    (echo "ERROR: ARCHON_SHA must be a 40-char hex commit hash, got '${ARCHON_SHA}'." \
     && echo "Resolve it: git ls-remote https://github.com/coleam00/Archon.git HEAD | cut -f1" \
     && exit 1)
RUN git clone https://github.com/coleam00/Archon.git . && \
    git checkout "${ARCHON_SHA}" && \
    git rev-parse HEAD > /opt/archon-sha && \
    bun install --frozen-lockfile --linker=hoisted

# ---------------------------------------------------------------------------
# Release process: resolve ${NODE_IMAGE} to an @sha256:... digest and
# update the default above to lock against image-registry drift.
FROM ${NODE_IMAGE}
ARG ARCHON_SHA

# Record supply-chain pins as OCI labels so `docker inspect` surfaces
# exactly which upstream SHA built this image.
LABEL org.sdlc.archon.sha="${ARCHON_SHA}"
LABEL org.sdlc.base-image="${NODE_IMAGE}"

# System dependencies (matching tests/integration/setup-smoke/Dockerfile)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv git curl ca-certificates xz-utils && \
    rm -rf /var/lib/apt/lists/* && \
    ln -sf /usr/bin/python3 /usr/bin/python

# Python dependencies for SDLC scripts (validation, team management, reporting)
RUN pip install --no-cache-dir --break-system-packages pyyaml

# Copy Bun runtime from the deps stage (avoids needing unzip for bun installer)
COPY --from=archon-deps /usr/local/bin/bun /usr/local/bin/bun
COPY --from=archon-deps /usr/local/bin/bunx /usr/local/bin/bunx

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code@2.1.107

# Copy Archon source from build stage (dependencies already installed)
COPY --from=archon-deps /opt/archon /opt/archon

# ARM64 workaround: Force Claude Agent SDK to use 'node' for subprocess.
# Bun's child_process stdin pipe handling hangs on ARM64 Linux when the SDK
# spawns cli.js in stream-json mode. This patch adds `executable: "node"` to
# Archon's SDK options so the subprocess runs on Node.js (stable on all archs)
# while Archon itself stays on Bun.
#
# This patch is conditional — only applied if Archon hasn't already set
# executable in the options. When Archon merges the upstream fix
# (see docs/issues/archon-arm64-sdk-executable.md), this becomes a no-op.
#
# Detection: grep for 'executable:' in the options block. If already present,
# Archon has the fix and we skip the patch.
RUN if ! grep -q 'executable:' /opt/archon/packages/core/src/clients/claude.ts; then \
      echo "Applying ARM64 workaround: executable: node"; \
      sed -i 's/pathToClaudeCodeExecutable: cliPath,/pathToClaudeCodeExecutable: cliPath,\n        executable: "node",/' \
        /opt/archon/packages/core/src/clients/claude.ts; \
    else \
      echo "Archon already sets executable — skipping ARM64 patch"; \
    fi

# Create archon wrapper script that runs from source via Bun.
#
# Note on the ContainerProvider patch that used to live here: we do not
# patch Archon's schema.  The preprocessor in scripts/preprocess_workflow.py
# rewrites image: nodes into bash: docker-run nodes BEFORE Archon sees the
# workflow, so Archon only ever processes its own native field set.  The
# earlier sed-based schema patch was both wrong (matched the first
# `command:` in the file — a ripgrep sub-schema, not the DAG node schema)
# and syntactically invalid (TypeScript interface syntax inside a Zod
# .object() call).  Removing it eliminates an entire class of bugs and
# keeps our delivery decoupled from any upstream Archon schema churn.
RUN printf '#!/bin/bash\nexec bun run /opt/archon/packages/cli/src/cli.ts "$@"\n' > /usr/local/bin/archon && \
    chmod +x /usr/local/bin/archon

# Build-time CLI verification (D-M-1 / repair plan phase B2).  A broken
# archon CLI must fail the image build, never ship silently.  Had this
# check existed from the start, it would have caught the bugs above at
# build time instead of letting them reach production images.
RUN archon --help >/dev/null 2>&1 || (echo "FATAL: archon --help failed in image build" >&2 && exit 1) && \
    archon workflow --help >/dev/null 2>&1 || (echo "FATAL: archon workflow subcommand broken" >&2 && exit 1)

# Ralph orchestrator (used by smoke tests and autonomous loops)
RUN npm install -g @ralph-orchestrator/ralph-cli@2.9.2

# Clean up build-only dependencies and artifacts
RUN apt-get purge -y --auto-remove xz-utils && \
    rm -rf /var/lib/apt/lists/* /opt/archon/.git

# Non-root user (UID 1001, matching smoke test convention — node:22-slim
# already has a 'node' user at UID 1000)
RUN useradd -m -s /bin/bash -u 1001 sdlc && \
    mkdir -p /workspace /home/sdlc/.claude /home/sdlc/.archon && \
    chown -R sdlc:sdlc /workspace /home/sdlc/.claude /home/sdlc/.archon /opt/archon

# Copy entrypoint (as root, before USER switch)
COPY docker/entrypoint.sh /opt/entrypoint.sh
RUN chmod +x /opt/entrypoint.sh

# SDLC helper scripts (loop workaround, future patches)
COPY scripts/detect-loop-bug.sh scripts/loop-workaround.sh /opt/sdlc-scripts/
RUN chmod +x /opt/sdlc-scripts/*.sh

# Health check: verify Claude Code binary is available
# S-M-8: exercise the binary (not just its presence bit) so a corrupted
# install, a missing node runtime, or a broken PATH is surfaced as
# `unhealthy` rather than silently blowing up at first workload call.
HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD claude --version >/dev/null 2>&1 || exit 1

USER sdlc
WORKDIR /workspace

ENTRYPOINT ["/opt/entrypoint.sh"]
