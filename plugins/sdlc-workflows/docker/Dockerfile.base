FROM oven/bun:latest AS archon-deps

# Install Archon from source (not the compiled binary).
# The compiled Bun binary has a $bunfs extraction issue that prevents
# the Claude Agent SDK from spawning child processes as a non-root user.
# Running from source with bun matches Archon's own Docker setup.
WORKDIR /opt/archon
RUN apt-get update && apt-get install -y --no-install-recommends git ca-certificates && \
    rm -rf /var/lib/apt/lists/*
RUN git clone --depth 1 https://github.com/coleam00/Archon.git . && \
    bun install --frozen-lockfile --linker=hoisted

# ---------------------------------------------------------------------------
FROM node:22-slim

# System dependencies (matching tests/integration/setup-smoke/Dockerfile)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv git curl ca-certificates xz-utils && \
    rm -rf /var/lib/apt/lists/* && \
    ln -sf /usr/bin/python3 /usr/bin/python

# Python dependencies for SDLC scripts (validation, team management, reporting)
RUN pip install --no-cache-dir --break-system-packages pyyaml

# Copy Bun runtime from the deps stage (avoids needing unzip for bun installer)
COPY --from=archon-deps /usr/local/bin/bun /usr/local/bin/bun
COPY --from=archon-deps /usr/local/bin/bunx /usr/local/bin/bunx

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code@2.1.107

# Copy Archon source from build stage (dependencies already installed)
COPY --from=archon-deps /opt/archon /opt/archon

# ARM64 workaround: Force Claude Agent SDK to use 'node' for subprocess.
# Bun's child_process stdin pipe handling hangs on ARM64 Linux when the SDK
# spawns cli.js in stream-json mode. This patch adds `executable: "node"` to
# Archon's SDK options so the subprocess runs on Node.js (stable on all archs)
# while Archon itself stays on Bun.
#
# This patch is conditional — only applied if Archon hasn't already set
# executable in the options. When Archon merges the upstream fix
# (see docs/issues/archon-arm64-sdk-executable.md), this becomes a no-op.
#
# Detection: grep for 'executable:' in the options block. If already present,
# Archon has the fix and we skip the patch.
RUN if ! grep -q 'executable:' /opt/archon/packages/core/src/clients/claude.ts; then \
      echo "Applying ARM64 workaround: executable: node"; \
      sed -i 's/pathToClaudeCodeExecutable: cliPath,/pathToClaudeCodeExecutable: cliPath,\n        executable: "node",/' \
        /opt/archon/packages/core/src/clients/claude.ts; \
    else \
      echo "Archon already sets executable — skipping ARM64 patch"; \
    fi

# SDLC patch: ContainerProvider + per-node image selection.
# Adds Docker-based isolation so different workflow nodes can run different
# team images. Conditional — skips if Archon already has the feature.
# See: https://github.com/coleam00/Archon/issues/1197
COPY patches/ /opt/sdlc-patches/
RUN chmod +x /opt/sdlc-patches/apply-patches.sh && \
    bash /opt/sdlc-patches/apply-patches.sh /opt/archon

# Create archon wrapper script that runs from source via Bun.
RUN printf '#!/bin/bash\nexec bun run /opt/archon/packages/cli/src/cli.ts "$@"\n' > /usr/local/bin/archon && \
    chmod +x /usr/local/bin/archon

# Ralph orchestrator (used by smoke tests and autonomous loops)
RUN npm install -g @ralph-orchestrator/ralph-cli@2.9.2

# Clean up build-only dependencies and artifacts
RUN apt-get purge -y --auto-remove xz-utils && \
    rm -rf /var/lib/apt/lists/* /opt/archon/.git

# Non-root user (UID 1001, matching smoke test convention — node:22-slim
# already has a 'node' user at UID 1000)
RUN useradd -m -s /bin/bash -u 1001 sdlc && \
    mkdir -p /workspace /home/sdlc/.claude /home/sdlc/.archon && \
    chown -R sdlc:sdlc /workspace /home/sdlc/.claude /home/sdlc/.archon /opt/archon

# Copy entrypoint (as root, before USER switch)
COPY docker/entrypoint.sh /opt/entrypoint.sh
RUN chmod +x /opt/entrypoint.sh

# SDLC helper scripts (loop workaround, future patches)
COPY scripts/detect-loop-bug.sh scripts/loop-workaround.sh /opt/sdlc-scripts/
RUN chmod +x /opt/sdlc-scripts/*.sh

# Health check: verify Claude Code binary is available
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD test -x /usr/local/bin/claude || exit 1

USER sdlc
WORKDIR /workspace

ENTRYPOINT ["/opt/entrypoint.sh"]
